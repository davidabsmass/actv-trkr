<?xml version="1.0"?>
<ruleset name="ACTV TRKR">
  <description>WordPress + Plugin VIP-Go ruleset for ACTV TRKR.</description>

  <file>.</file>

  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>node_modules/*</exclude-pattern>
  <exclude-pattern>tests/*</exclude-pattern>

  <arg name="extensions" value="php"/>
  <arg name="colors"/>
  <arg name="parallel" value="8"/>
  <arg value="ps"/>

  <!-- Core WordPress standards. -->
  <rule ref="WordPress">
    <!-- Lovable code conventions don't follow Yoda or short-array bans. -->
    <exclude name="WordPress.PHP.YodaConditions"/>
    <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
    <!-- File naming: we use class-foo.php which WPCS already accepts. -->
    <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    <!-- Comment punctuation noise — not worth blocking on. -->
    <exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
    <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
    <exclude name="Generic.Commenting.DocComment.MissingShort"/>
  </rule>

  <!-- Security-focused rules: keep ALL of these enabled. -->
  <rule ref="WordPress.Security"/>
  <rule ref="WordPress.WP.Capabilities"/>
  <rule ref="WordPress.WP.AlternativeFunctions"/>
  <rule ref="WordPress.DB.PreparedSQL"/>
  <rule ref="WordPress.DB.PreparedSQLPlaceholders"/>
  <rule ref="WordPress.DB.DirectDatabaseQuery"/>

  <!-- Plugin-specific text domain. -->
  <rule ref="WordPress.WP.I18n">
    <properties>
      <property name="text_domain" type="array">
        <element value="actv-trkr"/>
      </property>
    </properties>
  </rule>

  <!-- Minimum supported PHP. -->
  <config name="testVersion" value="7.4-"/>
  <config name="minimum_supported_wp_version" value="5.8"/>

  <rule ref="PHPCompatibilityWP"/>
</ruleset>
