{
  "name": "actvtrkr/wp-plugin",
  "description": "ACTV TRKR WordPress plugin — quality tooling.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^1.11",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "php-stubs/wordpress-stubs": "^6.5",
    "php-parallel-lint/php-parallel-lint": "^1.4"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "lint:php": "parallel-lint -j 8 --exclude vendor --exclude node_modules .",
    "phpcs": "phpcs --standard=.phpcs.xml",
    "phpcs:fix": "phpcbf --standard=.phpcs.xml",
    "phpcs:diff": "node ../scripts/phpcs-baseline.mjs",
    "phpstan": "phpstan analyse --memory-limit=512M",
    "phpstan:baseline": "phpstan analyse --memory-limit=512M --generate-baseline=phpstan-baseline.neon"
  }
}
