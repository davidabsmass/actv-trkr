includes:
  - vendor/szepeviktor/phpstan-wordpress/extension.neon
  - phpstan-baseline.neon

parameters:
  level: 5
  paths:
    - mission-metrics.php
    - includes
  excludePaths:
    - vendor/*
    - tests/*
  bootstrapFiles:
    - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
  ignoreErrors:
    # WP_CLI is loaded conditionally; calls are guarded by `defined('WP_CLI')`.
    - '#Call to static method [a-z_]+\(\) on an unknown class WP_CLI#i'
    - '#Class WP_CLI not found#'
